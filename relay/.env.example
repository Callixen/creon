# CREON Relay — environment configuration
# Copy to .env and fill in your values: cp .env.example .env

# ---- Required for agent chat ----
OPENCLAW_GATEWAY_URL=http://localhost:18789   # Your OpenClaw gateway URL
OPENCLAW_GATEWAY_TOKEN=your-token-here       # Your gateway auth token
OPENCLAW_AGENT_ID=main                       # Agent ID (default: main)

# ---- Optional API keys (data sources work without these, but rate limits apply) ----
NEWSDATA_API_KEY=                            # newsdata.io — https://newsdata.io
BLS_API_KEY=                                 # BLS API key — https://data.bls.gov/registrationEngine/
ALPHAVANTAGE_KEY=                            # Alpha Vantage (fallback markets data)

# ---- Server config ----
PORT=18900                                   # Relay port (default: 18900)
DASHBOARD_ORIGIN=                            # Leave blank for local dev (allows all origins)
                                             # Set to your domain in production: https://creon.live
LOG_LEVEL=info                               # debug | info | warn | error
